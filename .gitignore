# Ignore IDE and editor project files
.idea/
*.iml
*.ipr
*.iws
.vscode/

# Ignore build artifacts
target/
**/target/
build/
**/build/
dist/

# Ignore node modules and package manager files
node_modules/
**/node_modules/

# Ignore logs and temporary files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tmp
*.swp

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore environment and local config
.env
.env.local
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example
# Ignore Java build outputs
*.class
*.jar
*.war
*.ear

# Ignore database files
*.db
*.sqlite
